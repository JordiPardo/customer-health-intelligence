# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — production canonical URL (Vercel: https://your-app.vercel.app)
# NEXT_PUBLIC_SITE_URL=

# Optional — direct Postgres (Settings → Database → Connection string → URI)
# Use for seeding if REST API schema cache is stale: python scripts/seed_supabase.py --postgres
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# AI retention brief (server-only — add to Vercel Production env too)
OPENAI_API_KEY=sk-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
